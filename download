# =============================================================================
# FarmDirect Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# Django
# -----------------------------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=change-me-to-a-long-random-string-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_DB=farmdirect
POSTGRES_USER=farmdirect
POSTGRES_PASSWORD=farmdirect_secret
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# CORS
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost

# Email (SMTP)
# -----------------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@farmdirect.com

# Frontend
# -----------------------------------------------------------------------------
REACT_APP_API_URL=http://localhost:8000/api

# Stripe (Payments)
# -----------------------------------------------------------------------------
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# AWS S3 (Optional - for media storage in production)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# Sentry (Optional - error tracking)
# -----------------------------------------------------------------------------
SENTRY_DSN=
